# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Token do bot do Telegram (obtido via @BotFather)
TELEGRAM_TOKEN=seu_token_do_botfather_aqui

# URL do Ollama
# Docker Compose: http://ollama:11434
# Local: http://localhost:11434
OLLAMA_HOST=http://ollama:11434

# Configuração do Servidor
HOST=0.0.0.0
PORT=8000
DEBUG=False

# URL pública para o Webhook do Telegram
WEBHOOK_URL=https://seu-dominio.com/webhook/telegram
