# =============================================================================
# Supply Chain Chatbot — Configuração de Ambiente
# =============================================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA faça commit do arquivo .env (já está no .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# OBRIGATÓRIO — Token do bot do Telegram
# Como obter: abra o Telegram, procure @BotFather, envie /newbot
# Formato:    123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=seu_token_do_botfather_aqui

# -----------------------------------------------------------------------------
# URL do Ollama (IA local)
# Docker Compose → use o nome do serviço: http://ollama:11434
# Rodando local  → use localhost:          http://localhost:11434
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434

# -----------------------------------------------------------------------------
# Porta da API (padrão: 8000)
# Acesso local: http://localhost:8000
# Docs Swagger: http://localhost:8000/docs
# -----------------------------------------------------------------------------
PORT=8000
